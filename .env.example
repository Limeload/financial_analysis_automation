# ── Infrastructure ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://firehose:firehose@localhost:5432/firehose
REDIS_URL=redis://localhost:6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9094   # use 9092 inside Docker network

# ── PostgreSQL (used by docker-compose) ─────────────────────────
POSTGRES_USER=firehose
POSTGRES_PASSWORD=firehose
POSTGRES_DB=firehose

# ── News feed API keys ───────────────────────────────────────────
THENEWSAPI_KEY=your_thenewsapi_token_here
# Add more feed API keys here as new adapters are added

# ── LLM ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here          # optional fallback
LLM_PROVIDER=anthropic                        # anthropic | openai
LLM_MODEL=claude-sonnet-4-6                   # override per environment

# ── API authentication ───────────────────────────────────────────
# Comma-separated list of valid API keys (for dev; use DB in prod)
API_KEYS=dev-secret-key-1,dev-secret-key-2

# ── Ingestion tuning ─────────────────────────────────────────────
INGESTION_INTERVAL_SECONDS=60
KAFKA_TOPIC_RAW=raw-articles
KAFKA_CONSUMER_GROUP=firehose-processor

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
